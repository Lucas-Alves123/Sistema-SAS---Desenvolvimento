# Configuração do Banco de Dados PostgreSQL
# Altere os valores conforme sua configuração local
SQLALCHEMY_DATABASE_URI=postgresql://postgres:5432@localhost:5432/sga_db

# Ambiente da aplicação: development, production, testing
FLASK_ENV=development

# Chave secreta para a aplicação (mude em produção!)
SECRET_KEY=dev-key-change-in-production

# Debug mode (true para desenvolvimento, false para produção)
FLASK_DEBUG=true
